generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostType {
  TEXT
  VIDEO
  IMAGE
  AUDIO
  LINK
  FILE
}

enum MediaType {
  HLS_VIDEO
  IMAGE
  ATTACHMENT
  EMBED
}

model CreatorAccount {
  id                String           @id @default(uuid())
  name              String
  patreonSessionId  String?
  sessionExpiresAt  DateTime?
  patreonCampaignId String?
  lastSyncAt        DateTime?
  cursor            String?
  status            String           @default("idle")
  errorLog          String?
  isOwned           Boolean          @default(true)
  parentAccountId   String?
  parentAccount     CreatorAccount?  @relation("FollowedAccounts", fields: [parentAccountId], references: [id], onDelete: Cascade)
  followedAccounts  CreatorAccount[] @relation("FollowedAccounts")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  posts             Post[]
}

model Post {
  id               String          @id @default(uuid())
  patreonId        String?         @unique
  title            String
  content          String?
  contentHtml      String?
  type             PostType        @default(TEXT)
  thumbnailUrl     String?
  embedHtml        String?
  publishedAt      DateTime        @default(now())
  isPublished      Boolean         @default(true)
  tags             String[]        @default([])
  creatorAccountId String?
  creatorAccount   CreatorAccount? @relation(fields: [creatorAccountId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  media            Media[]
}

model Media {
  id               String    @id @default(uuid())
  postId           String
  post             Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  type             MediaType @default(HLS_VIDEO)
  url              String?
  filename         String?
  hlsManifestUrl   String?
  hlsExpiresAt     DateTime?
  hlsRefreshedAt   DateTime?
  patreonMediaId   String?
  thumbnailUrl     String?
  duration         Int?
  width            Int?
  height           Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model SyncState {
  id        String    @id @default("main")
  updatedAt DateTime  @updatedAt
}

