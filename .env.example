# ============================================================
# PatronHub — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- Database (PostgreSQL) ---
# Get one from: Neon (neon.tech), Supabase (supabase.com), or Railway (railway.app)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# --- Patreon Sync ---
# Paste your session_id cookie from patreon.com (DevTools → Application → Cookies)
# Leave blank — you'll enter it via the admin dashboard after deploying.
PATREON_SESSION_ID=""

# Optional: Cloudflare __cf_bm cookie to bypass bot detection
PATREON_CF_BM_COOKIE=""

# Optional: Explicit Patreon campaign ID (auto-detected if omitted)
PATREON_CAMPAIGN_ID=""

# --- HLS Refresh ---
# Optional: Buffer minutes before HLS expiry to trigger refresh (default: 30)
HLS_REFRESH_INTERVAL_MINUTES="30"

# --- Cron Job Protection ---
# Generate with: openssl rand -hex 32
# Protects /api/cron/* endpoints from unauthorized access
CRON_SECRET="replace-with-random-32-byte-hex"
