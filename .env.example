# ============================================================
# PatronHub — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- Database (PostgreSQL) ---
# Get one from: Neon (neon.tech), Supabase (supabase.com), or Railway (railway.app)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# --- Auth.js v5 ---
# Generate with: openssl rand -hex 32
AUTH_SECRET="replace-with-random-32-byte-hex"
# Your deployed URL (e.g. https://your-app.vercel.app)
AUTH_URL="http://localhost:3000"

# --- Email (Magic Links) ---
# SMTP connection string. Providers with free tiers:
#   Resend:       smtp://resend:your-api-key@smtp.resend.com:587
#   SendGrid:     smtp://apikey:your-api-key@smtp.sendgrid.net:587
#   Brevo:        smtp://your-login:your-password@smtp.brevo.com:587
EMAIL_SERVER="smtp://user:password@smtp.resend.com:587"
EMAIL_FROM="noreply@yourdomain.com"

# --- Patreon Sync ---
# Paste your session_id cookie from patreon.com (DevTools → Application → Cookies)
# Leave blank — you'll enter it via the admin dashboard after deploying.
PATREON_SESSION_ID=""

# Optional: Cloudflare __cf_bm cookie to bypass bot detection
PATREON_CF_BM_COOKIE=""

# --- Cron Job Protection ---
# Generate with: openssl rand -hex 32
# Protects /api/cron/* endpoints from unauthorized access
CRON_SECRET="replace-with-random-32-byte-hex"
